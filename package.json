{
  "name": "pt-bookings",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:server": "tsx e2e/seed.ts && next dev --port 3001",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local src/lib/db/migrate.ts",
    "db:seed": "tsx --env-file=.env.local src/lib/db/seed.ts",
    "db:reset": "tsx --env-file=.env.local src/lib/db/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3",
    "nanoid": "^5.1.2",
    "next": "^15.1.6",
    "pg": "^8.13.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
