DATABASE_URL=postgresql://user:password@host:port/database
# Isolated Postgres for npm test / e2e only — never wipe or seed DATABASE_URL (dev data)
TEST_DATABASE_URL=postgresql://user:password@host:port/database_test
# Must include https:// on Railway, e.g. https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
