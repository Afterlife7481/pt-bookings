DATABASE_URL=postgresql://user:password@host:port/database
# Isolated Postgres for npm test / e2e only — never wipe or seed DATABASE_URL (dev data)
TEST_DATABASE_URL=postgresql://user:password@host:port/database_test
# Public URL for magic links, WhatsApp messages, and client session links.
# On Railway, APP_BASE_URL is read at runtime (recommended for deployed servers).
# NEXT_PUBLIC_APP_URL is also supported and is inlined for client-side code at build time.
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to 0 to hide magic links on Railway once email is wired up
# EXPOSE_DEV_MAGIC_LINKS=1
